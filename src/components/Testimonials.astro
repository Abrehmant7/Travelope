---
const testimonials = [
  { name: 'Sarah Jenkins', role: 'Digital Nomad', text: 'Travelpe secured a notoriously difficult European digital nomad visa for me in record time. Their destination profiling is insanely accurate.' },
  { name: 'Marcus Sterling', role: 'Business Executive', text: 'I travel constantly for enterprise deals. They manage my multi-entry business visas and hotel upgrades automatically. Flawless service.' },
  { name: 'Elena Rostova', role: 'Leisure Traveler', text: 'We wanted a secluded Maldives package without the standard tourist traps. The itinerary they built was breathtaking, and completely hassle-free.' },
  { name: 'Dr. Amir Khan', role: 'Medical Conference Attendee', text: 'My US visa appointment was delayed by 6 months. Travelpe tracked the embassy system and bumped me up within 3 weeks.' },
  { name: 'Sophie Laurent', role: 'Expedition Guide', text: 'They handled the extreme logistics of my South American documentation flawlessly. Highly recommended for complex border requirements.' }
];
---
<section class="py-24 bg-orange-50 relative overflow-hidden border-b border-orange-100">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#0a2540] tracking-tight mb-4">Client <span class="text-[#f97316]">Experiences</span></h2>
        <p class="text-slate-600 font-medium text-lg">Hear from the executives, nomads, and explorers who trust our systems.</p>
      </div>
      <div class="flex gap-4">
        <button id="prev-btn" class="w-12 h-12 rounded-full border-2 border-slate-200 bg-white flex items-center justify-center text-[#0a2540] hover:bg-[#f97316] hover:border-[#f97316] hover:text-white shadow-sm transition-all">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" /></svg>
        </button>
        <button id="next-btn" class="w-12 h-12 rounded-full border-2 border-slate-200 bg-white flex items-center justify-center text-[#0a2540] hover:bg-[#f97316] hover:border-[#f97316] hover:text-white shadow-sm transition-all">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" /></svg>
        </button>
      </div>
    </div>

    <!-- Slider Container -->
    <div class="overflow-hidden relative -mx-4 px-4 pb-12">
      <div id="slider-track" class="flex transition-transform duration-500 ease-out" style="transform: translateX(0%);">
        {testimonials.map((test) => (
          <div class="w-full sm:w-[calc(50%-16px)] lg:w-[calc(33.333%-21px)] flex-shrink-0 mx-2 lg:mx-4">
            <div class="bg-white border border-slate-100 p-8 rounded-3xl h-full shadow-lg hover:shadow-xl hover:border-slate-200 transition-all">
              <div class="flex items-center gap-1 mb-6 text-[#f97316]">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </div>
              <p class="text-slate-600 font-medium italic mb-8 leading-relaxed">"{test.text}"</p>
              <div class="mt-auto">
                <h4 class="text-[#0a2540] font-black">{test.name}</h4>
                <p class="text-[#f97316] text-sm font-bold">{test.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById('slider-track');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  if (track && prevBtn && nextBtn) {
    let index = 0;
    const cards = track.children;
    
    const getCardsToShow = () => {
      if (window.innerWidth >= 1024) return 3;
      if (window.innerWidth >= 640) return 2;
      return 1;
    };

    const updateSlider = () => {
      const cardsToShow = getCardsToShow();
      const maxIndex = cards.length - cardsToShow;
      
      if (index < 0) index = 0;
      if (index > maxIndex) index = maxIndex;
      
      const percentage = (index * 100) / cardsToShow;
      track.style.transform = `translateX(-${percentage}%)`;
    };

    nextBtn.addEventListener('click', () => {
      index++;
      updateSlider();
    });

    prevBtn.addEventListener('click', () => {
      index--;
      updateSlider();
    });

    window.addEventListener('resize', updateSlider);
  }
</script>
