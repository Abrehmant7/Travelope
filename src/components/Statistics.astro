---
const stats = [
  { label: 'Visas Approved', value: '12,500+' },
  { label: 'Destinations', value: '50+' },
  { label: 'Consultants', value: '24/7' },
  { label: 'Success Rate', value: '98%' }
];
---
<section class="py-20 relative overflow-hidden bg-slate-50 border-y border-slate-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-12 gap-x-8 text-center divide-x divide-slate-200">
      {stats.map(stat => (
        <div class="flex flex-col justify-center px-4 first:border-l-0 border-l border-slate-200 hover:scale-105 transition-transform duration-300">
          <div class="text-4xl md:text-6xl text-[#f97316] font-black tracking-tight mb-2 drop-shadow-sm">{stat.value}</div>
          <div class="text-[#0a2540] text-xs sm:text-sm uppercase tracking-widest font-bold">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
