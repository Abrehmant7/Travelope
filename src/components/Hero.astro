---
---
<!-- We remove all manual negative margins and set it to a pure min-h-screen setup. -->
<!-- We use min-h-[85vh] on mobile and drop it to min-h-[75vh] on large screens to shrink the height. -->
<section class="relative w-full min-h-[85vh] lg:min-h-[85vh] flex flex-col justify-center items-center pb-32 mb-32 md:mb-24">
  
  <!-- Background Image & Overlays -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?auto=format&fit=crop&q=80&w=2000" 
      alt="Travel Background" 
      fetchpriority="high"
      loading="eager"
      decoding="sync"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a2540]/95 via-[#0a2540]/70 to-[#0a2540]/95 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] opacity-30 mix-blend-overlay"></div>
  </div>

  <!-- Quantum Vista Style Animations -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-[30vw] h-[30vw] bg-[#f97316] rounded-full blur-[140px] opacity-30 animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[40vw] h-[40vw] bg-[#0a2540] rounded-full blur-[160px] opacity-70"></div>
  </div>

  <!-- Centered Hero Content -->
  <div class="relative z-10 text-center px-4 w-full max-w-5xl mx-auto flex flex-col items-center justify-center mt-20"> <!-- mt-20 accounts for the absolute navbar visually -->
    <div class="relative inline-block mb-6 md:mb-8">
      <h1 class="text-[4rem] sm:text-7xl md:text-8xl lg:text-9xl font-black text-white tracking-tighter drop-shadow-2xl leading-none">
        Travel<span class="text-[#f97316]">ope</span>
      </h1>
      <!-- Animated Orbit/Plane Path Graphic - Scaled dynamically -->
      <svg class="absolute -top-4 -right-8 md:-top-6 md:-right-12 w-24 h-24 md:w-32 md:h-32 text-[#f97316] opacity-80 animate-[spin_10s_linear_infinite]" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4">
        <circle cx="50" cy="50" r="40" />
      </svg>
      <div class="absolute -top-6 -right-4 md:-top-8 md:-right-8 text-[#f97316] animate-bounce">
        <svg class="w-6 h-6 md:w-8 md:h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/></svg>
      </div>
    </div>
    
    <p class="text-xl md:text-2xl lg:text-3xl text-slate-200 font-bold tracking-widest uppercase drop-shadow-lg max-w-2xl">
      WE HELP YOU TRAVEL TO EUROPE
    </p>
  </div>

  <!-- Floating Search/Booking Bar -->
  <!-- We use translate-y-1/2 to perfectly sit exactly halfway over the bottom edge, regardless of how tall the bar gets on mobile -->
  <div class="absolute bottom-0 translate-y-1/2 left-1/2 -translate-x-1/2 w-[90%] md:w-[95%] max-w-5xl z-30">
    <div class="bg-white/95 backdrop-blur-xl rounded-3xl shadow-[0_30px_60px_rgba(10,37,64,0.2)] border border-white p-3 md:p-3 flex flex-col md:flex-row items-stretch gap-4 md:gap-2">
      
      <!-- Container for Tabs (Horizontal on mobile, inline on desktop) -->
      <div class="flex flex-row justify-between items-center w-full md:flex-1 gap-2">
        
        <!-- Tab 1: Packages -->
        <div data-tab="packages" class="hero-tab flex-1 flex flex-col md:flex-row items-center justify-center md:justify-start gap-2 md:gap-4 p-2 md:p-4 rounded-2xl hover:bg-slate-50 transition-colors cursor-pointer group text-center md:text-left">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#0a2540]/5 flex items-center justify-center text-[#0a2540] group-hover:bg-[#f97316] group-hover:text-white transition-colors flex-shrink-0">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest hidden md:block">Explore</p>
            <p class="text-[#0a2540] font-black text-xs md:text-xl mt-1 md:mt-0">Packages</p>
          </div>
        </div>

        <div class="hidden md:block w-px bg-slate-200 my-4 mx-0 lg:mx-2 h-10"></div>

        <!-- Tab 2: Visas -->
        <div data-tab="visas" class="hero-tab flex-1 flex flex-col md:flex-row items-center justify-center md:justify-start gap-2 md:gap-4 p-2 md:p-4 rounded-2xl hover:bg-slate-50 transition-colors cursor-pointer group text-center md:text-left">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#0a2540]/5 flex items-center justify-center text-[#0a2540] group-hover:bg-[#f97316] group-hover:text-white transition-colors flex-shrink-0">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </div>
          <div>
            <p class="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest hidden md:block">Service</p>
            <p class="text-[#0a2540] font-black text-xs md:text-xl mt-1 md:mt-0">Visas</p>
          </div>
        </div>

        <div class="hidden md:block w-px bg-slate-200 my-4 mx-0 lg:mx-2 h-10"></div>

        <!-- Tab 3: Flights -->
        <div data-tab="flights" class="hero-tab flex-1 flex flex-col md:flex-row items-center justify-center md:justify-start gap-2 md:gap-4 p-2 md:p-4 rounded-2xl hover:bg-slate-50 transition-colors cursor-pointer group text-center md:text-left">
          <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#0a2540]/5 flex items-center justify-center text-[#0a2540] group-hover:bg-[#f97316] group-hover:text-white transition-colors flex-shrink-0">
            <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <div>
            <p class="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest hidden md:block">Book</p>
            <p class="text-[#0a2540] font-black text-xs md:text-xl mt-1 md:mt-0">Flights</p>
          </div>
        </div>
      </div>

      <!-- Action Button -->
      <a id="hero-search-btn" href="/contact" class="w-full md:w-auto md:ml-4 bg-[#f97316] hover:bg-[#0a2540] text-white rounded-2xl px-8 py-4 flex items-center justify-center gap-3 font-extrabold text-lg md:text-xl transition-all shadow-[0_10px_25px_rgba(249,115,22,0.4)] hover:shadow-xl hover:-translate-y-1">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
        Search
      </a>
      
    </div>
  </div>
</section>

<script>
  function initHeroTabs() {
    const tabs = document.querySelectorAll(".hero-tab");
    const searchBtn = document.getElementById("hero-search-btn");

    if (!tabs.length || !searchBtn) return;

    let selectedTab = "packages"; // Default selected tab

    function updateTabs() {
      tabs.forEach((tab) => {
        const tabType = tab.getAttribute("data-tab");
        const iconContainer = tab.querySelector("div");
        
        if (tabType === selectedTab) {
          // Active state
          tab.classList.add("bg-slate-50", "ring-2", "ring-[#f97316]", "ring-inset");
          if (iconContainer) {
            iconContainer.classList.replace("bg-[#0a2540]/5", "bg-[#f97316]");
            iconContainer.classList.replace("text-[#0a2540]", "text-white");
          }
        } else {
          // Inactive state
          tab.classList.remove("bg-slate-50", "ring-2", "ring-[#f97316]", "ring-inset");
          if (iconContainer) {
            iconContainer.classList.replace("bg-[#f97316]", "bg-[#0a2540]/5");
            iconContainer.classList.replace("text-white", "text-[#0a2540]");
          }
        }
      });

      // Update Search button destination
      if (selectedTab === "visas") {
        searchBtn.setAttribute("href", "/#schengen-visa");
      } else {
        // packages and flights go to main form
        searchBtn.setAttribute("href", "/#lead-form");
      }
    }

    // Attach click events
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        selectedTab = tab.getAttribute("data-tab") || "packages";
        updateTabs();
      });
    });

    // Initialize UI
    updateTabs();
  }

  // Astro scripts are type="module" (deferred), so DOM is already parsed
  initHeroTabs();
  document.addEventListener('astro:page-load', initHeroTabs);
</script>
