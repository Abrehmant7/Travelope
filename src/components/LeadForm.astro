---

---

<section id="lead-form" class="py-16 bg-slate-50 relative border-b border-slate-100 scroll-mt-24">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="bg-[#0a2540] rounded-3xl shadow-[0_20px_50px_rgba(10,37,64,0.2)] p-8 md:p-12 relative overflow-hidden"
    >
      <!-- Subtle background pattern inside the blue form card -->
      <div
        class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] opacity-20 pointer-events-none"
      >
      </div>
      <div
        class="absolute -top-32 -right-32 w-96 h-96 bg-[#f97316] rounded-full blur-[150px] opacity-20 pointer-events-none"
      >
      </div>

      <div class="mb-10 text-center md:text-left relative z-10">
        <h2
          class="text-3xl md:text-4xl font-black text-white uppercase tracking-wide mb-2"
        >
          Start Your <span class="text-[#f97316]">Journey</span>
        </h2>
        <p class="text-slate-300 font-medium text-lg">
          Fill in the details below to get a customized travel itinerary.
        </p>
      </div>

      <form
        action="https://api.web3forms.com/submit"
        method="POST"
        id="journey-form"
        class="relative z-10"
      >
        <input
          type="hidden"
          name="access_key"
          value="4b529110-3db9-47e2-9cae-5817e7eebfbc"
        />
        <input
          type="hidden"
          name="subject"
          value="New Custom Itinerary Request - Travelope"
        />

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
          <!-- Row 1 -->
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2"
              >Full Name</label
            >
            <input
              type="text"
              name="name"
              required
              placeholder="John Doe"
              class="w-full bg-[#16385d]/80 border border-white/5 text-white placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none shadow-inner"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2"
              >Email Address</label
            >
            <input
              type="email"
              name="email"
              required
              placeholder="john@example.com"
              class="w-full bg-[#16385d]/80 border border-white/5 text-white placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none shadow-inner"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2"
              >Phone Number</label
            >
            <input
              type="tel"
              name="phone"
              required
              placeholder="+1 (555) 000-0000"
              class="w-full bg-[#16385d]/80 border border-white/5 text-white placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none shadow-inner"
            />
          </div>

          <!-- Row 2 -->
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2"
              >Destination</label
            >
            <input
              type="text"
              name="destination"
              required
              placeholder="New York"
              class="w-full bg-[#16385d]/80 border border-white/5 text-white placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none shadow-inner"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2"
              >Nationality</label
            >
            <input
              type="text"
              name="nationality"
              required
              placeholder="Enter Nationality"
              class="w-full bg-[#16385d]/80 border border-white/5 text-white placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none shadow-inner"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-300 mb-2"
              >Current City</label
            >
            <input
              type="text"
              name="current_city"
              required
              placeholder="Enter Current City"
              class="w-full bg-[#16385d]/80 border border-white/5 text-white placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none shadow-inner"
            />
          </div>
        </div>

        <div class="flex justify-end border-t border-white/10 pt-8 mt-4">
          <button
            type="submit"
            class="bg-[#f97316] hover:bg-white hover:text-[#0a2540] text-white rounded-xl px-10 py-4 font-bold text-lg transition-all shadow-[0_10px_20px_rgba(249,115,22,0.3)] hover:shadow-[0_15px_30px_rgba(255,255,255,0.4)] hover:-translate-y-1"
          >
            Get My Free Quote
          </button>
        </div>

        <p id="form-result" class="mt-4 text-center font-bold hidden"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("journey-form") as HTMLFormElement;
  const result = document.getElementById("form-result");

  if (form && result) {
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      result.textContent = "Please wait...";
      result.classList.remove("hidden", "text-red-400", "text-[#f97316]");
      result.classList.add("text-slate-400");

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.classList.remove("text-slate-400");
            result.classList.add("text-[#f97316]");
            result.textContent =
              "Request submitted successfully! Our travel architects will contact you shortly.";
            form.reset();
          } else {
            console.log(response);
            result.classList.remove("text-slate-400");
            result.classList.add("text-red-400");
            result.textContent = json.message || "Something went wrong!";
          }
        })
        .catch((error) => {
          console.log(error);
          result.classList.remove("text-slate-400");
          result.classList.add("text-red-400");
          result.textContent = "Something went wrong!";
        })
        .finally(() => {
          setTimeout(() => {
            result.classList.add("hidden");
          }, 5000);
        });
    });
  }
</script>
