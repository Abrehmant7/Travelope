---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
---

<Layout title="Refund Policy | Travelope Premium Consultancy">
  <!-- Inner Page Hero -->
  <div class="relative pt-40 pb-20 overflow-hidden bg-[#0a2540]">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a2540]/80 to-slate-50"></div>
    </div>
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <span class="inline-block py-1.5 px-4 rounded-full bg-white/10 text-white font-bold text-sm tracking-widest uppercase mb-6 shadow-sm border border-white/20 backdrop-blur-sm">Legal</span>
      <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-6 drop-shadow-lg">Refund <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f97316] to-[#fdba74]">Policy</span></h1>
      <p class="text-xl text-slate-200 font-medium max-w-2xl mx-auto leading-relaxed drop-shadow-md">Transparent & Fair. We are committed to providing exceptional visa consultation services with complete transparency.</p>
    </div>
  </div>

  <section class="py-24 bg-slate-50 text-slate-600 text-lg">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="bg-white rounded-3xl shadow-sm border border-slate-200 p-8 md:p-12 lg:p-16">
        
        <p class="text-xl text-slate-600 font-medium mb-12 leading-relaxed">
          This refund policy outlines the terms and conditions governing refund requests for our services. Please read carefully to understand under what circumstances refunds are issued.
        </p>

        <h2 class="text-3xl font-bold text-[#0a2540] mt-12 mb-6 flex items-center">
          <span class="w-8 h-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center mr-4 shadow-sm border border-green-200"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" /></svg></span>
          Eligible for Refund
        </h2>
        <p class="mb-6 font-medium">We offer refunds under the following circumstances:</p>
        <div class="space-y-6">
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-xl font-bold text-[#0a2540] mb-2">Duplicate Payments</h3>
            <p class="text-slate-600 text-base">If you have been inadvertently charged multiple times for the same service due to technical or processing errors on our part.</p>
          </div>
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-xl font-bold text-[#0a2540] mb-2">Service Delivery Failure</h3>
            <p class="text-slate-600 text-base">If we are unable to commence or complete your visa application processing due to circumstances within our control or operational errors.</p>
          </div>
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-xl font-bold text-[#0a2540] mb-2">Pre-Processing Cancellation</h3>
            <p class="text-slate-600 text-base">If you choose to cancel your application before we have initiated the processing phase and no work has been undertaken on your behalf.</p>
          </div>
        </div>

        <h2 class="text-3xl font-bold text-[#0a2540] mt-16 mb-6 flex items-center">
          <span class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center mr-4 shadow-sm border border-red-200"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg></span>
          Non-Refundable Situations
        </h2>
        <p class="mb-6 font-medium">Please note that refunds will not be provided in the following situations:</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-lg font-bold text-[#0a2540] mb-2">Embassy/Consulate Decision</h3>
            <p class="text-slate-600 text-sm">Visa rejection or refusal by the relevant embassy, consulate, or immigration authority.</p>
          </div>
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-lg font-bold text-[#0a2540] mb-2">Applications in Progress</h3>
            <p class="text-slate-600 text-sm">Cases where your application has been officially submitted to the relevant authorities or is currently under review.</p>
          </div>
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-lg font-bold text-[#0a2540] mb-2">Client-Related Issues</h3>
            <p class="text-slate-600 text-sm">Applications affected by incorrect, incomplete, or misleading information provided by the applicant.</p>
          </div>
          <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100">
            <h3 class="text-lg font-bold text-[#0a2540] mb-2">Third-Party Fees</h3>
            <p class="text-slate-600 text-sm">Government fees, embassy charges, or other third-party costs that have been paid on your behalf.</p>
          </div>
        </div>

        <hr class="my-12 border-slate-200" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-[#0a2540] mb-6">Submission Requirements</h2>
            <ul class="space-y-3 text-slate-600 list-disc pl-5">
              <li>All refund requests must be submitted in writing via email to <strong>info@travelope.uk</strong>.</li>
              <li>Requests must be made within <strong>seven (7) calendar days</strong> of the original payment date.</li>
              <li>Please include your transaction reference number, payment details, and reason for the refund request.</li>
            </ul>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-[#0a2540] mb-6">Processing Timeline</h2>
            <ul class="space-y-3 text-slate-600 list-disc pl-5">
              <li>Refund requests will be reviewed and processed within <strong>7-10 business days</strong> from the date of receipt.</li>
              <li>Approved refunds will be credited to the original payment method used for the transaction.</li>
              <li>You will receive email confirmation once the refund has been processed.</li>
            </ul>
          </div>
        </div>

        <hr class="my-12 border-slate-200" />

        <h2 class="text-2xl font-bold text-[#0a2540] mb-4">Important Notes</h2>
        <ul class="space-y-3 text-slate-600 list-disc pl-5 mb-12">
          <li>Refund amounts may be subject to applicable processing fees charged by payment providers.</li>
          <li>Partial refunds may apply depending on the stage of service completion.</li>
          <li>This policy is subject to applicable consumer protection laws in the United Kingdom.</li>
        </ul>

        <div class="bg-[#f97316]/10 p-8 rounded-2xl border border-[#f97316]/20 text-center">
          <h2 class="text-2xl font-bold text-[#0a2540] mb-2">Have Questions?</h2>
          <p class="text-slate-600 mb-6">For refund requests, inquiries, or clarification regarding this policy, please contact us:</p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="mailto:info@travelope.uk" class="font-bold text-[#f97316] hover:text-[#0a2540] transition-colors">info@travelope.uk</a>
            <span class="hidden sm:inline text-slate-300">|</span>
            <a href="tel:+447727748251" class="font-bold text-[#f97316] hover:text-[#0a2540] transition-colors">+44 7727748251</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Cta />
</Layout>
