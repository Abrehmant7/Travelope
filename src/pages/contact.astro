---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';
---

<Layout title="Contact Us | Travelope Premium Consultancy">
  <!-- Inner Page Hero -->
  <div class="relative pt-40 pb-20 overflow-hidden bg-[#0a2540]">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a2540]/80 to-slate-50"></div>
    </div>
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <span class="inline-block py-1.5 px-4 rounded-full bg-white/10 text-white font-bold text-sm tracking-widest uppercase mb-6 shadow-sm border border-white/20 backdrop-blur-sm">Get in Touch</span>
      <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-6 drop-shadow-lg">Contact <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f97316] to-[#fdba74]">Us</span></h1>
      <p class="text-xl text-slate-200 font-medium max-w-2xl mx-auto leading-relaxed drop-shadow-md">Get in touch with us to start your journey. Our customer support team is here to assist you 24/7.</p>
    </div>
  </div>

  <section class="py-24 bg-slate-50 relative overflow-hidden">
    <!-- Decorative background element -->
    <div class="absolute top-0 right-0 w-1/2 h-full bg-white/50 backdrop-blur-3xl rounded-l-[100px] pointer-events-none hidden lg:block"></div>
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        
        <!-- Contact Info (Left) -->
        <div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-[#0a2540] mb-8">We're here to help you cross borders seamlessly.</h2>
          <p class="text-lg text-slate-600 mb-12 font-medium">Whether you need urgent visa assistance, have a question about our packages, or want to explore new destinations, our expert advisors are on standby.</p>
          
          <div class="space-y-8">
            <!-- Email -->
            <div class="flex items-start">
              <div class="w-14 h-14 rounded-2xl bg-orange-50 flex items-center justify-center text-[#f97316] flex-shrink-0 mt-1 shadow-sm border border-orange-100">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div class="ml-6">
                <h3 class="text-xl font-bold text-[#0a2540] mb-1">Email Us</h3>
                <p class="text-slate-600 mb-2 font-medium">For general inquiries and support.</p>
                <a href="mailto:info@travelope.uk" class="text-[#f97316] font-bold hover:text-[#0a2540] transition-colors text-lg">info@travelope.uk</a>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start">
              <div class="w-14 h-14 rounded-2xl bg-orange-50 flex items-center justify-center text-[#f97316] flex-shrink-0 mt-1 shadow-sm border border-orange-100">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div class="ml-6">
                <h3 class="text-xl font-bold text-[#0a2540] mb-1">Call Us</h3>
                <p class="text-slate-600 mb-2 font-medium">Available 24/7 for urgent consultations.</p>
                <div class="flex flex-col space-y-1">
                  <a href="tel:+447727748251" class="text-[#f97316] font-bold hover:text-[#0a2540] transition-colors text-lg">+44 7727748251</a>
                </div>
              </div>
            </div>

            <!-- Location -->
            <div class="flex items-start">
              <div class="w-14 h-14 rounded-2xl bg-orange-50 flex items-center justify-center text-[#f97316] flex-shrink-0 mt-1 shadow-sm border border-orange-100">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div class="ml-6">
                <h3 class="text-xl font-bold text-[#0a2540] mb-1">Visit Us</h3>
                <p class="text-slate-600 mb-2 font-medium">Our corporate headquarters.</p>
                <p class="text-[#0a2540] font-bold text-lg">3 Maryam close Rainham<br/>RM 13 9PE, London</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form (Right) -->
        <div class="bg-white rounded-3xl shadow-xl border border-slate-100 p-8 md:p-12 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-[#f97316]/5 rounded-bl-full -z-10"></div>
          
          <h3 class="text-2xl font-black text-[#0a2540] mb-2">Send a Message</h3>
          <p class="text-slate-500 font-medium mb-8">Fill this form out and our agents will reach out to you soon.</p>
          
          <form action="https://api.web3forms.com/submit" method="POST" id="contact-form" class="space-y-6">
            <input type="hidden" name="access_key" value="4b529110-3db9-47e2-9cae-5817e7eebfbc" />
            <input type="hidden" name="subject" value="New General Contact Request - Travelope" />

            <div>
              <label class="block text-sm font-bold text-[#0a2540] mb-2">Full Name</label>
              <input type="text" name="name" required placeholder="John Doe" class="w-full bg-slate-50 border border-slate-200 text-[#0a2540] placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-bold text-[#0a2540] mb-2">Email Address</label>
                <input type="email" name="email" required placeholder="john@example.com" class="w-full bg-slate-50 border border-slate-200 text-[#0a2540] placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none" />
              </div>
              <div>
                <label class="block text-sm font-bold text-[#0a2540] mb-2">Phone Number</label>
                <input type="tel" name="phone" required placeholder="+44 123 456 789" class="w-full bg-slate-50 border border-slate-200 text-[#0a2540] placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-[#0a2540] mb-2">Message</label>
              <textarea name="message" required rows="4" placeholder="How can we help you?" class="w-full bg-slate-50 border border-slate-200 text-[#0a2540] placeholder-slate-400 text-base rounded-xl focus:ring-2 focus:ring-[#f97316] focus:border-[#f97316] block p-3.5 transition-colors outline-none resize-none"></textarea>
            </div>

            <button type="submit" class="w-full bg-[#f97316] hover:bg-[#0a2540] text-white rounded-xl px-8 py-4 font-bold text-lg transition-all shadow-[0_10px_20px_rgba(249,115,22,0.3)] hover:shadow-lg hover:-translate-y-0.5">
              Send Message
            </button>
            <p id="contact-result" class="text-center font-bold hidden mt-4"></p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <Cta />
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const result = document.getElementById("contact-result");

  if (form && result) {
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      result.textContent = "Sending message...";
      result.classList.remove("hidden", "text-red-500", "text-green-600");
      result.classList.add("text-slate-500");

      fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: json,
      })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.classList.remove("text-slate-500");
            result.classList.add("text-green-600");
            result.textContent = "Message Sent! Thank you for contacting us. Our team will get back to you shortly.";
            form.reset();
          } else {
            console.log(response);
            result.classList.remove("text-slate-500");
            result.classList.add("text-red-500");
            result.textContent = json.message || "Something went wrong!";
          }
        })
        .catch((error) => {
          console.log(error);
          result.classList.remove("text-slate-500");
          result.classList.add("text-red-500");
          result.textContent = "Something went wrong!";
        })
        .finally(() => {
          setTimeout(() => {
            result.classList.add("hidden");
          }, 8000);
        });
    });
  }
</script>
