---
import Layout from "../../layouts/Layout.astro";
import BlogCards from "../../components/blog-cards.astro";
import Cta from "../../components/Cta.astro";

import { Image } from "astro:assets";
import heroImage from "../../assets/service 3.jpg";
---

<Layout title="Travel Blog | Travelope Premium Consultancy">
  <div class="relative pt-40 pb-20 overflow-hidden bg-[#0a2540]">
    <div class="absolute inset-0 z-0">
      <Image 
        src={heroImage} 
        alt="Travel Blog" 
        widths={[640, 1024, 1920]} 
        sizes="100vw"
        loading="eager"
        format="webp"
        class="w-full h-full object-cover opacity-20 mix-blend-overlay" 
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#0a2540]/90 via-[#0a2540]/80 to-slate-50"></div>
    </div>
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <span class="inline-block py-1.5 px-4 rounded-full bg-white/10 text-white font-bold text-sm tracking-widest uppercase mb-6 shadow-sm border border-white/20 backdrop-blur-sm">Insights</span>
      <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-6 drop-shadow-lg">Travel <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f97316] to-[#fdba74]">Blog</span></h1>
      <p class="text-xl text-slate-200 font-medium max-w-2xl mx-auto leading-relaxed drop-shadow-md">Tips, guides, and inspiration for your next adventure across the globe.</p>
    </div>
  </div>

  <BlogCards />

  <Cta />
</Layout>
