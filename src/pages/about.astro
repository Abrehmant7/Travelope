---
import Layout from '../layouts/Layout.astro';
import OurProcess from '../components/OurProcess.astro';
import Cta from '../components/Cta.astro';
import { Image } from 'astro:assets';
import logoImg from '../assets/trvalope logo.png';
---

<Layout title="About Us | Travelope Premium Consultancy">
  <!-- CSS Animations -->
  <style>
    @keyframes blob {
      0% { transform: translate(0px, 0px) scale(1); }
      33% { transform: translate(30px, -50px) scale(1.1); }
      66% { transform: translate(-20px, 20px) scale(0.9); }
      100% { transform: translate(0px, 0px) scale(1); }
    }
    .animate-blob { animation: blob 10s infinite alternate ease-in-out; }
    .animation-delay-2000 { animation-delay: 2s; }
    .animation-delay-4000 { animation-delay: 4s; }
  </style>

  <!-- Inner Page Hero -->
  <div class="relative pt-40 pb-28 overflow-hidden">
    <!-- Animated Background -->
    <div class="absolute inset-0 z-0 overflow-hidden bg-[#0a2540]">
      <!-- Floating Orbs -->
      <div class="absolute -top-[20%] -left-[10%] w-[50%] h-[50%] rounded-full bg-[#f97316]/20 blur-[120px] animate-blob"></div>
      <div class="absolute top-[20%] -right-[10%] w-[40%] h-[60%] rounded-full bg-[#facc15]/10 blur-[100px] animate-blob animation-delay-2000"></div>
      <div class="absolute -bottom-[20%] left-[20%] w-[60%] h-[50%] rounded-full bg-[#16385d]/40 blur-[130px] animate-blob animation-delay-4000"></div>
      <!-- Grid -->
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a2540]/80 to-slate-50"></div>
    </div>
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center mt-12 mb-8">
      <span class="inline-block py-1.5 px-4 rounded-full bg-white/10 text-white font-bold text-sm tracking-widest uppercase mb-6 shadow-sm border border-white/20 backdrop-blur-sm">Our Story</span>
      <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight mb-8 drop-shadow-lg">The Architects of <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f97316] to-[#fdba74]">Travel</span></h1>
      <p class="text-xl text-slate-200 font-medium max-w-3xl mx-auto leading-relaxed drop-shadow-md">We believe that global mobility should be a right, not a bureaucratic hurdle. Discover the team redefining international travel.</p>
    </div>
  </div>

  <!-- Mission & Vision Split -->
  <section class="w-full">
    <div class="flex flex-col lg:flex-row w-full">
      
      <!-- Left text area -->
      <div class="w-full lg:w-1/2 bg-white px-6 py-16 lg:px-24 lg:py-32 flex flex-col justify-center">
        <div class="max-w-2xl mx-auto lg:mx-0 lg:ml-auto">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#0a2540] tracking-tight leading-tight">We are more than just a <br class="hidden md:block"/>travel agency.</h2>
          <div class="w-20 h-1.5 bg-[#eac54f] mt-8 mb-10"></div>
          <p class="text-lg text-slate-600 leading-relaxed font-medium mb-8">
            At Travelope, we believe that travel is the only thing you buy that makes you richer. Founded on a passion for exploration and a commitment to excellence, we have grown into a trusted partner for travelers worldwide.
          </p>
          <p class="text-lg text-slate-600 leading-relaxed font-medium">
            Our mission is simple: to remove the stress of planning so you can focus on the joy of discovery. Whether you are seeking a serene escape, an adrenaline-fueled adventure, or a cultural immersion, our team of dedicated experts is here to make your dream trip a reality. From intricate visa procedures to securing the best seats on the plane, we handle every detail with precision and care.
          </p>
        </div>
      </div>

      <!-- Right image area (Logo replace) -->
      <div class="w-full lg:w-1/2 bg-slate-50 p-8 lg:p-16 flex items-center justify-center min-h-[400px] lg:min-h-[500px]">
        <Image src={logoImg} alt="Travelope Logo" class="w-full max-w-sm lg:max-w-md h-auto object-contain hover:scale-105 transition-transform duration-500 drop-shadow-xl" />
      </div>

    </div>
  </section>

  <!-- Core Values Section -->
  <section class="py-24 bg-slate-50 border-y border-slate-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="text-4xl md:text-5xl font-black text-[#0a2540] tracking-tight mb-6">The Travelope Standard</h2>
        <p class="text-lg text-slate-600 font-medium">Why elite travelers and business professionals exclusively trust us with their international mobility.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
        <!-- Value 1 -->
        <div class="bg-white p-8 lg:p-10 rounded-3xl shadow-xl border border-slate-100 group hover:-translate-y-2 transition-all duration-300">
          <div class="w-14 h-14 lg:w-16 lg:h-16 rounded-2xl bg-orange-50 flex items-center justify-center text-[#f97316] mb-6 lg:mb-8 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 lg:w-8 lg:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          </div>
          <h3 class="text-xl lg:text-2xl font-bold text-[#0a2540] mb-3 lg:mb-4">Absolute Transparency</h3>
          <p class="text-slate-600 leading-relaxed font-medium text-sm lg:text-base">No hidden fees, no opaque application updates, and no false promises. We operate with complete clarity from day one.</p>
        </div>

        <!-- Value 2 -->
        <div class="bg-white p-8 lg:p-10 rounded-3xl shadow-xl border border-slate-100 group hover:-translate-y-2 transition-all duration-300">
          <div class="w-14 h-14 lg:w-16 lg:h-16 rounded-2xl bg-orange-50 flex items-center justify-center text-[#f97316] mb-6 lg:mb-8 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 lg:w-8 lg:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-xl lg:text-2xl font-bold text-[#0a2540] mb-3 lg:mb-4">Relentless Execution</h3>
          <p class="text-slate-600 leading-relaxed font-medium text-sm lg:text-base">We do not just offer advice. We meticulously assemble, audit, and execute your visa applications and bookings.</p>
        </div>

        <!-- Value 3 -->
        <div class="bg-white p-8 lg:p-10 rounded-3xl shadow-xl border border-slate-100 group hover:-translate-y-2 transition-all duration-300">
          <div class="w-14 h-14 lg:w-16 lg:h-16 rounded-2xl bg-orange-50 flex items-center justify-center text-[#f97316] mb-6 lg:mb-8 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 lg:w-8 lg:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
          </div>
          <h3 class="text-xl lg:text-2xl font-bold text-[#0a2540] mb-3 lg:mb-4">Global Network</h3>
          <p class="text-slate-600 leading-relaxed font-medium text-sm lg:text-base">By leveraging our deep-rooted relationships with international embassies, we unlock doors that remain firmly shut to others.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Footprint Section -->
  <section class="py-24 bg-[#0a2540] relative overflow-hidden">
    <!-- Subtle Map Background -->
    <div class="absolute inset-0 z-0 opacity-10">
      <svg class="w-full h-full object-cover" viewBox="0 0 1000 500" fill="none" stroke="white" stroke-width="1" xmlns="http://www.w3.org/2000/svg">
         <!-- Abstract grid lines representing globe -->
         <path d="M0 100 H1000 M0 200 H1000 M0 300 H1000 M0 400 H1000" />
         <path d="M200 0 V500 M400 0 V500 M600 0 V500 M800 0 V500" />
         <circle cx="500" cy="250" r="300" />
         <circle cx="500" cy="250" r="200" />
         <circle cx="500" cy="250" r="100" />
      </svg>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-16">Our Global Footprint</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-8 divide-y md:divide-y-0 md:divide-x divide-white/10">
        <!-- Stat 1 -->
        <div class="pt-8 md:pt-0">
          <div class="text-6xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-br from-[#f97316] to-[#fdba74] mb-4 drop-shadow-lg">27</div>
          <div class="text-white font-bold tracking-widest uppercase text-sm">Schengen States</div>
          <div class="text-slate-400 mt-2 text-sm font-medium">Seamless borderless access</div>
        </div>
        <!-- Stat 2 -->
        <div class="pt-12 md:pt-0">
          <div class="text-6xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-br from-[#f97316] to-[#fdba74] mb-4 drop-shadow-lg">50+</div>
          <div class="text-white font-bold tracking-widest uppercase text-sm">Partner Embassies</div>
          <div class="text-slate-400 mt-2 text-sm font-medium">Direct processing channels</div>
        </div>
        <!-- Stat 3 -->
        <div class="pt-12 md:pt-0">
          <div class="text-6xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-br from-[#f97316] to-[#fdba74] mb-4 drop-shadow-lg">10k+</div>
          <div class="text-white font-bold tracking-widest uppercase text-sm">Visas Processed</div>
          <div class="text-slate-400 mt-2 text-sm font-medium">Flawless execution rate</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull in other components -->
  <OurProcess />
  <Cta />
</Layout>
