---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/Cta.astro';

const faqs = [
  {
    question: "Can I track my visa application status?",
    answer: "Yes, our services include continuous application tracking with regular status updates, delivering complete visibility and confidence throughout your application journey."
  },
  {
    question: "Data Privacy and Security with Our Schengen Visa Consultancy?",
    answer: "Data security and privacy are fundamental priorities in our service delivery. We utilize advanced encryption technologies that meet industry standards to protect your personal information throughout all transmission processes. Our fully GDPR-compliant infrastructure ensures responsible data management through stringent access controls and a minimal data collection policy, gathering only information essential for visa application requirements."
  },
  {
    question: "Documents Needed to Apply for a Schengen Visa?",
    answer: "A valid passport is required, and our expert team will assist with other documents like travel itineraries, accommodation proof, financial statements, and travel insurance. We guide you through every step for a smooth visa process."
  },
  {
    question: "What is the Processing Time for a Visa Application?",
    answer: "Processing times vary by country due to local regulations and requirements. We are committed to providing an efficient and seamless experience, with typical processing times ranging from several business days to several weeks, depending on the complexity and jurisdiction involved."
  },
  {
    question: "Do you guarantee visa approval?",
    answer: "Although we achieve consistently high success rates, ultimate approval is contingent upon meeting specific embassy requirements. Our expert team maximizes your chances of success by providing meticulous documentation preparation and comprehensive application guidance."
  }
];
---

<Layout title="FAQs | Travelope Premium Consultancy">
  <!-- Inner Page Hero -->
  <div class="relative pt-40 pb-20 overflow-hidden bg-[#0a2540]">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0a2540]/80 to-slate-50"></div>
    </div>
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-6 drop-shadow-lg">Frequently Asked <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#f97316] to-[#fdba74]">Questions</span></h1>
      <p class="text-xl text-slate-200 font-medium max-w-2xl mx-auto leading-relaxed drop-shadow-md">Everything you need to know about our visa processing and consultancy services.</p>
    </div>
  </div>

  <!-- FAQs Section -->
  <section class="py-24 bg-slate-50 min-h-[50vh]">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      
      <div class="space-y-6">
        {faqs.map((faq, index) => (
          <details class="group bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden transition-all duration-300 hover:shadow-md" open={index === 0}>
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-6 text-xl text-[#0a2540] transition-colors duration-300">
              <span class="pr-6 leading-snug">{faq.question}</span>
              <span class="transition-all duration-300 transform group-open:-rotate-180 w-10 h-10 flex-shrink-0 flex items-center justify-center rounded-full bg-slate-100 text-slate-600 group-open:bg-[#eac54f] group-open:text-[#0a2540]">
                <svg fill="none" height="24" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24" width="24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </span>
            </summary>
            <div class="p-6 pt-0 text-slate-600 leading-relaxed font-medium border-t border-slate-100 bg-white mt-2">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>

    </div>
  </section>

  <Cta />
</Layout>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
